rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // ── Utilizadores ──────────────────────────────────────────
    match /users/{userId} {
      allow read:                   if isOwner(userId) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ── Incidentes ────────────────────────────────────────────
    // Segurança real: userId obrigatoriamente == utilizador autenticado
    // Impede impersonação e garante rastreabilidade
    match /incidents/{incidentId} {
      allow read:   if isAuth();
      allow create: if isAuth()
                    && request.resource.data.userId == request.auth.uid
                    && 'partName' in request.resource.data;
      allow update: if isAuth()
                    && (isOwner(resource.data.userId) || isAdmin())
                    && (!('userId' in request.resource.data)
                        || request.resource.data.userId == resource.data.userId);
      allow delete: if isAuth()
                    && (isOwner(resource.data.userId) || isAdmin());
    }

    // ── Numeração CAR ─────────────────────────────────────────
    match /carNumbers/{docId} {
      allow read:          if isAuth();
      allow create:        if isAuth();
      allow update, delete: if isAdmin();
    }

    // ── Base de peças (partsDB) ───────────────────────────────
    match /partsDB/{partId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ── Stock ─────────────────────────────────────────────────
    match /stock/{partId} {
      allow read:  if isAuth();
      allow write: if isAuth();
    }

    // ── Movimentos de stock ───────────────────────────────────
    match /stockMovements/{moveId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow delete: if isAdmin();
    }

  }
}
